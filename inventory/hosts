# The [local] group runs Ansible directly on this machine — no IP address or
# SSH setup needed. This is the simplest way to configure the machine you are
# currently working on (e.g. right after a fresh OS install).
[local]
localhost ansible_connection=local

# The [linux] and [macos] groups are for configuring remote machines over SSH.
# You only need these if you want to manage other machines on your network.
[linux]
# e.g. my-linux-machine ansible_host=192.168.1.10 ansible_user=myuser

[macos]
# e.g. my-mac ansible_host=192.168.1.20 ansible_user=myuser
